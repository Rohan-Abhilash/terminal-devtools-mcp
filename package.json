{
    "name": "tui-tester",
    "version": "0.1.0",
    "description": "A Model Context Protocol (MCP) server that gives AI agents full programmatic control of terminal user interfaces (TUIs) — spawn them in a real PTY, send any key combination, and read back the rendered screen.",
    "type": "module",
    "main": "dist/index.js",
    "bin": {
        "tui-tester": "dist/index.js",
        "tui-tester-mcp": "dist/index.js"
    },
    "scripts": {
        "build": "tsc --noEmit && tsup",
        "typecheck": "tsc --noEmit",
        "dev": "tsup --watch",
        "start": "node dist/index.js",
        "test": "node --experimental-vm-modules node_modules/.bin/jest --config jest.config.cjs",
        "test:watch": "node --experimental-vm-modules node_modules/.bin/jest --config jest.config.cjs --watch",
        "test:e2e": "node --experimental-vm-modules node_modules/.bin/jest --config jest.config.cjs --testPathPatterns=e2e",
        "prepublishOnly": "npm run build"
    },
    "keywords": [
        "mcp",
        "model-context-protocol",
        "tui",
        "terminal",
        "terminal-testing",
        "testing",
        "pty",
        "node-pty",
        "xterm",
        "xterm-headless",
        "ai-agent",
        "automation",
        "e2e"
    ],
    "author": "Rohan Abhilash",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/Rohan-Abhilash/terminal-devtools-mcp.git"
    },
    "bugs": {
        "url": "https://github.com/Rohan-Abhilash/terminal-devtools-mcp/issues"
    },
    "homepage": "https://github.com/Rohan-Abhilash/terminal-devtools-mcp#readme",
    "engines": {
        "node": ">=18.0.0"
    },
    "files": [
        "dist",
        "README.md",
        "LICENSE",
        "CHANGELOG.md"
    ],
    "dependencies": {
        "@homebridge/node-pty-prebuilt-multiarch": "^0.13.1",
        "@modelcontextprotocol/sdk": "^1.24.2",
        "@xterm/headless": "^5.5.0",
        "zod": "^3.23.8"
    },
    "devDependencies": {
        "@jest/globals": "^29.7.0",
        "@types/jest": "^29.5.12",
        "@types/node": "^20.11.0",
        "jest": "^29.7.0",
        "ts-jest": "^29.2.5",
        "tsup": "^8.3.0",
        "typescript": "^5.5.4"
    }
}
